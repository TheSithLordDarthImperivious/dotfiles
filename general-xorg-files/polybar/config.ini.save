;
;==========================================================

[colors]
background = #CC222B30
background-hover = #CC51636D
foreground = #BDE6FB
primary = #0078D7
secondary = #BDE6FB
alert = #ffd700
disabled = #151c19

[bar/main-bar]
width = 100%
height = 22pt

dpi = ${xrdb:Xft.dpi:96}

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2pt

border-size = 3pt
border-color = ${colors.background}

padding-left = 2
padding-right = 2

module-margin = 2

font-0 = Ubuntu Nerd Font:style=Light:size=12;2
font-1 = Font Awesome 6 Free Solid:style=Regular;2
font-2 = Noto Color Emoji:style=Regular:scale=10;2

modules-left = rofi windowswitcher filebrowser xworkspaces xwindow
modules-right = cpu memory filesystem pulseaudio battery wlan eth date power

wm-restack = generic

[settings]
screenchange-reload = true
pseudo-transparency = false
override-redirect = true

[module/rofi]
type = custom/text
click-left = rofi -dpi `xrdb -q | grep Xft.dpi | sed --expression='s/Xft.dpi://'` -show drun
content = "ůįÄĽ"
content-padding = 2
content-underline = #0063B1
label = "ůįÄĽ"
label-padding = 2
label-underline = #0063B1

[module/windowswitcher]
type = custom/text
click-left = rofi -dpi `xrdb -q | grep Xft.dpi | sed --expression='s/Xft.dpi://'` -show window -kb-accept-entry '!Alt-Tab,!Alt-ISO_Left_Tab,Return' -kb-row-down 'Alt-Tab,Alt-Down,Down' -kb-row-up 'Alt-ISO_Left_Tab,Alt-Up,Up' -kb-cancel "Alt-Escape,Escape"
content = "Ó¨£"
content-padding = 2
content-underline = #0276ab
label = "Ó¨£"
label-padding = 2
label-underline = #0276ab

[module/filebrowser]
type = custom/text
click-left = rofi -dpi `xrdb -q | grep Xft.dpi | sed --expression='s/Xft.dpi://'` -show filebrowser
content = "Ó™É"
content-padding = 2
content-underline = #107C10
label = "Ó™É"
label-padding = 2
label-underline = #107C10

[module/xworkspaces]
type = internal/xworkspaces

label-active = %name%
label-active-background = ${colors.background-hover}
label-active-underline= #0078D7
label-active-padding = 3

label-occupied = %name%
label-occupied-padding = 3

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 3

label-empty = %name%
label-empty-padding = 3

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%
format = <label>
label-maxlen = 31
label-empty = Desktop
format-underline = #02a0fc

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = Ôā†  %mountpoint%  %percentage_used%%

label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.disabled}

label-mounted-underline = #7702fc
label-unmounted-underline = #7702fc

[module/alsa]
type = internal/alsa

format-volume = <ramp-volume> <label-volume>
label-volume = %percentage:2%%

label-muted = ůįēŅ Muted

ramp-volume-0 = ůįēŅ
ramp-volume-1 = ůįĖÄ
ramp-volume-2 = ůįēĺ

format-volume-underline = #4FC978
label-muted-underline = #A6C900

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

label-layout = %layout%
label-layout-foreground = ${colors.foreground}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-foreground = ${colors.background}
label-indicator-background = ${colors.secondary}

[module/memory]
type = internal/memory
interval = 2
label = ÓČ¶ %percentage_used:2%%
label-underline = #01af95

[module/cpu]
type = internal/cpu
interval = 2
format = %{T2}Ôíľ%{T-} <label>
label = %percentage:2%%
ramp-coreload-spacing = 1
ramp-coreload-0 = ‚ĖĀ
ramp-coreload-1 = ‚Ėā
ramp-coreload-2 = ‚ĖÉ
ramp-coreload-3 = ‚ĖĄ
ramp-coreload-4 = ‚ĖÖ
ramp-coreload-5 = ‚ĖÜ
ramp-coreload-6 = ‚Ėá
ramp-coreload-7 = ‚Ėą
;format-underline = #0c50b5
format-underline = #F4BF75

[network-base]
type = internal/network
interval = 5
format-connected = <label-connected>
format-disconnected = <label-disconnected>
label-disconnected = ůį≤ú Disconnected
format-connected-underline = #0e50f7
label-disconnected-underline = #B90E0A

[module/wlan]
inherit = network-base
interface-type = wireless
format-connected = <ramp-signal> <label-connected>
label-connected = %essid%
label-maxlen = 12

ramp-signal-0 = ůį§Į
ramp-signal-1 = ůį§ü
ramp-signal-2 = ůį§ü
ramp-signal-3 = ůį§•
ramp-signal-4 = ůį§®

[module/eth]
inherit = network-base
interface-type = wired
format = <label>
label-connected = ůįąĀ %ifname%

[module/date]
type = internal/date
interval = 1

date = %H:%M:%S
date-alt = %Y-%m-%d

label = ůĪĎá %date%
format = <label>

;format-underline = #186b6b
format-underline = #75B5AA

[module/battery]
type = internal/battery
low-at = 10
battery = BAT0
adapter = ADP1
format-charging = %{T2}<animation-charging>%{T-}  <label-charging>
format-discharging = %{T2}<ramp-capacity>%{T-}  <label-discharging>
format-charging-underline = #FFFF33
format-discharging-underline = #ED7014

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ

animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750

animation-discharging-0 = ÔČÄ
animation-discharging-1 = ÔČĀ
animation-discharging-2 = ÔČā
animation-discharging-3 = ÔČÉ
animation-discharging-4 = ÔČĄ
animation-discharging-framerate = 500

label-full = %{T2}ÔČÄ%{T-}  100%
label-full-underline = #1FFF0F

[module/power]
type1 = custom/text
click-left = rofi -show power-menu -dpi `xrdb -q | grep Xft.dpi | sed --expression='s/Xft.dpi://'` -modi power-menu:'~/.config/rofi/rofi-power-menu' -no-show-icons
content = "ÔÄĎ"
content-padding = 2
content-underline = #B30000
label = "ÔÄĎ"
label-padding = 2
label-underline = #B30000
